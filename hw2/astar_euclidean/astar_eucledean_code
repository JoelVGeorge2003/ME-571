import sys
from PIL import Image
import queue as Queue
import math
import matplotlib.pyplot as plt

start = (0, 0)
end = (0, 0)
difficulty = ""
G = 0
E = 0
e_list = []

# Display colors
NEON_GREEN = (0, 255, 0)      # start / goal
PURPLE = (85, 26, 139)        # final path
LIGHT_GRAY = (180, 180, 180)  # frontier
DARK_GRAY = (90, 90, 90)      # expanded / visited nodes

# Search data structures
path = []
expanded = {}
frontier = {}

open_set = Queue.PriorityQueue()
came_from = {}
cost_so_far = {}


def reset_search_state():
    global path, expanded, frontier, open_set, came_from, cost_so_far, G
    path = []
    expanded = {}
    frontier = {}
    open_set = Queue.PriorityQueue()
    came_from = {}
    cost_so_far = {}
    G = 10**18


def valid_neighbor(pixel_map, x, y, width, height):
    if x < 0 or x >= width or y < 0 or y >= height:
        return False
    if pixel_map[x, y] == 0:
        return False
    return True


def reconstruct_path():
    global path
    path = []

    if end not in came_from:
        return

    current = end
    while current is not None:
        path.append(current)
        current = came_from[current]

    path.reverse()


def heuristic(node, goal, heuristic_type="euclidean"):
    x1, y1 = node
    x2, y2 = goal

    if heuristic_type == "euclidean":
        return math.sqrt((x1 - x2) ** 2 + (y1 - y2) ** 2)

    elif heuristic_type == "manhattan":
        return abs(x1 - x2) + abs(y1 - y2)

    else:
        raise ValueError("Unsupported heuristic type: " + str(heuristic_type))


def search(pixel_map, width, height, heuristic_type="euclidean"):
    global G, expanded, frontier, came_from, cost_so_far

    directions = [(1, 0), (-1, 0), (0, 1), (0, -1)]

    open_set.put((0, start))
    came_from[start] = None
    cost_so_far[start] = 0
    frontier[start] = True

    while not open_set.empty():
        current_priority, current = open_set.get()

        if current in expanded:
            continue

        expanded[current] = True

        if current in frontier:
            del frontier[current]

        if current == end:
            G = cost_so_far[current]
            reconstruct_path()
            return

        for dx, dy in directions:
            nx = current[0] + dx
            ny = current[1] + dy
            neighbor = (nx, ny)

            if not valid_neighbor(pixel_map, nx, ny, width, height):
                continue

            new_cost = cost_so_far[current] + 1

            if neighbor not in cost_so_far or new_cost < cost_so_far[neighbor]:
                cost_so_far[neighbor] = new_cost
                came_from[neighbor] = current

                priority = new_cost + heuristic(neighbor, end, heuristic_type)
                open_set.put((priority, neighbor))

                if neighbor not in expanded:
                    frontier[neighbor] = True

    G = -1
    reconstruct_path()


def visualize_search(heuristic_type, save_file="astar_result.png"):
    im = Image.open(difficulty).convert("RGB")
    pixel_access = im.load()

    # Draw expanded nodes
    for pixel in expanded.keys():
        pixel_access[pixel[0], pixel[1]] = DARK_GRAY

    # Draw frontier nodes
    for pixel in frontier.keys():
        pixel_access[pixel[0], pixel[1]] = LIGHT_GRAY

    # Draw final path
    for pixel in path:
        pixel_access[pixel[0], pixel[1]] = PURPLE

    # Draw start and goal
    pixel_access[start[0], start[1]] = NEON_GREEN
    pixel_access[end[0], end[1]] = NEON_GREEN

    im.save(save_file)

    plt.figure(figsize=(10, 8))
    plt.imshow(im)
    plt.title("A* Search Result - " + heuristic_type.capitalize())

    plt.text(start[0] + 3, start[1] + 3, "START", color='lime', fontsize=10)
    plt.text(end[0] + 3, end[1] + 3, "GOAL", color='lime', fontsize=10)

    plt.xlabel("Heuristic = {0}, Final path cost = {1}, Expanded nodes = {2}".format(heuristic_type, G, len(expanded)))
    plt.ylabel("Maze Y")
    plt.tight_layout()
    plt.savefig("labeled_" + save_file)
    plt.show()

    im.close()


def set_start_end(difficulty_name):
    global start, end

    if difficulty_name == "trivial.gif" or difficulty_name == "maps/trivial.gif":
        start = (8, 1)
        end = (20, 1)

    elif difficulty_name == "medium.gif" or difficulty_name == "maps/medium.gif":
        start = (8, 201)
        end = (110, 1)

    elif difficulty_name == "hard.gif" or difficulty_name == "maps/hard.gif":
        start = (10, 1)
        end = (401, 220)

    elif difficulty_name == "super_hard.gif" or difficulty_name == "maps/super_hard.gif":
        start = (10, 1)
        end = (401, 220)

    elif difficulty_name == "very_hard.gif" or difficulty_name == "maps/very_hard.gif":
        start = (1, 324)
        end = (580, 1)

    elif difficulty_name == "my_maze.gif" or difficulty_name == "maps/my_maze.gif":
        start = (0, 0)
        end = (500, 205)

    elif difficulty_name == "my_maze2.gif" or difficulty_name == "maps/my_maze2.gif":
        start = (0, 0)
        end = (599, 350)

    else:
        raise AssertionError("Incorrect difficulty level provided")


def run_astar(pixel_map, width, height, heuristic_type):
    
    global G

    reset_search_state()
    search(pixel_map, width, height, heuristic_type)

    print("A* completed with", heuristic_type, "heuristic")
    print("Start node: ", start)
    print("Goal node:  ", end)
    print("Final path cost: ", G)
    print("Number of expanded nodes: ", len(expanded))
    print("Path length (pixels/nodes in path): ", len(path))

    save_name = "astar_" + heuristic_type + ".png"
    visualize_search(heuristic_type, save_name)

    return {
        "heuristic": heuristic_type,
        "path_cost": G,
        "expanded_nodes": len(expanded),
        "path_length": len(path)
    }


if __name__ == "__main__":
    function_name = str(sys.argv[0])
    difficulty = str(sys.argv[1])
    print("running " + function_name + " with " + difficulty + " difficulty.")

    set_start_end(difficulty)

    im = Image.open(difficulty).convert('1')
    pixel_map = im.load()
    width, height = im.size

    # Run both heuristics
    euclidean_result = run_astar(pixel_map, width, height, "euclidean")
    manhattan_result = run_astar(pixel_map, width, height, "manhattan")

    print("Euclidean heuristic:")
    print("  Final path cost:", euclidean_result["path_cost"])
    print("  Expanded nodes:", euclidean_result["expanded_nodes"])
    print("  Path length:", euclidean_result["path_length"])


    print("\nComparison:")
    if euclidean_result["expanded_nodes"] < manhattan_result["expanded_nodes"]:
        print("  Euclidean expanded fewer nodes.")
    elif manhattan_result["expanded_nodes"] < euclidean_result["expanded_nodes"]:
        print("  Manhattan expanded fewer nodes.")
    else:
        print("  Both expanded the same number of nodes.")

    if euclidean_result["path_cost"] == manhattan_result["path_cost"]:
        print("  Both found paths with the same final cost.")
    else:
        print("  The final path costs were different.")