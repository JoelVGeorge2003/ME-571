import sys
from PIL import Image
import queue as Queue
import matplotlib.pyplot as plt

# Runtime-set variables from the assignment skeleton
start = (0, 0)
end = (0, 0)
difficulty = ""
G = 0
E = 0
e_list = []

# Display colors
NEON_GREEN = (0, 255, 0)      # start / goal
PURPLE = (85, 26, 139)        # final path
LIGHT_GRAY = (180, 180, 180)  # frontier
DARK_GRAY = (90, 90, 90)      # expanded / visited nodes
RED = (255, 0, 0)             # optional highlight

# Search data structures
path = []          # ordered list from start to goal
expanded = {}      # visited / expanded nodes
frontier = {}      # nodes discovered but not yet expanded

open_set = Queue.PriorityQueue()
came_from = {}
cost_so_far = {}


def valid_neighbor(pixel_map, x, y, width, height):
    
    if x < 0 or x >= width or y < 0 or y >= height:
        return False
    if pixel_map[x, y] == 0:
        return False
    return True


def reconstruct_path():
    
    global path

    path = []
    if end not in came_from:
        return

    current = end
    while current is not None:
        path.append(current)
        current = came_from[current]

    path.reverse()


def search(pixel_map, width, height):
    
    global G, expanded, frontier, came_from, cost_so_far

    # 4-connected movement: right, left, down, up
    directions = [(1, 0), (-1, 0), (0, 1), (0, -1)]

    while not open_set.empty():
        current_priority, current = open_set.get()

        # Ignore stale queue entries
        if current in expanded:
            continue

        # Mark current node as expanded
        expanded[current] = True

        # Remove from frontier once expanded
        if current in frontier:
            del frontier[current]

        # Stop when goal is reached
        if current == end:
            G = cost_so_far[current]
            reconstruct_path()
            return

        # Explore neighbors
        for dx, dy in directions:
            nx = current[0] + dx
            ny = current[1] + dy
            neighbor = (nx, ny)

            if not valid_neighbor(pixel_map, nx, ny, width, height):
                continue

            new_cost = cost_so_far[current] + 1

            # Standard Dijkstra relaxation
            if neighbor not in cost_so_far or new_cost < cost_so_far[neighbor]:
                cost_so_far[neighbor] = new_cost
                came_from[neighbor] = current
                open_set.put((new_cost, neighbor))

                # Mark discovered nodes as frontier until expanded
                if neighbor not in expanded:
                    frontier[neighbor] = True

    # If goal not found
    G = -1
    reconstruct_path()


def visualize_search(save_file="dijkstra_result.png"):
    
    im = Image.open(difficulty).convert("RGB")
    pixel_access = im.load()

    # Draw expanded / visited nodes
    for pixel in expanded.keys():
        pixel_access[pixel[0], pixel[1]] = DARK_GRAY

    # Draw frontier nodes
    for pixel in frontier.keys():
        pixel_access[pixel[0], pixel[1]] = LIGHT_GRAY

    # Draw final path
    for pixel in path:
        pixel_access[pixel[0], pixel[1]] = PURPLE

    # Draw start and end after everything else so they stay visible
    pixel_access[start[0], start[1]] = NEON_GREEN
    pixel_access[end[0], end[1]] = NEON_GREEN

    # Save image
    im.save(save_file)

    # Show labeled plot with matplotlib
    plt.figure(figsize=(10, 8))
    plt.imshow(im)
    plt.title("Dijkstra Search Result")

    # Labels
    plt.text(start[0] + 3, start[1] + 3, "START", color='lime', fontsize=10)
    plt.text(end[0] + 3, end[1] + 3, "GOAL", color='lime', fontsize=10)

    plt.xlabel("Final path cost = {0}, Expanded nodes = {1}".format(G, len(expanded)))
    plt.ylabel("Maze Y")
    plt.tight_layout()
    plt.savefig("dijkstra_labeled_result.png")
    plt.show()

    im.close()


if __name__ == "__main__":
    function_name = str(sys.argv[0])
    difficulty = str(sys.argv[1])
    print("running " + function_name + " with " + difficulty + " difficulty.")

    # Start and goal positions from assignment skeleton
    if difficulty == "trivial.gif" or difficulty == "maps/trivial.gif":
        start = (8, 1)
        end = (20, 1)

    elif difficulty == "medium.gif" or difficulty == "maps/medium.gif":
        start = (8, 201)
        end = (110, 1)

    elif difficulty == "hard.gif" or difficulty == "maps/hard.gif":
        start = (10, 1)
        end = (401, 220)

    elif difficulty == "super_hard.gif" or difficulty == "maps/super_hard.gif":
        start = (10, 1)
        end = (401, 220)

    elif difficulty == "very_hard.gif" or difficulty == "maps/very_hard.gif":
        start = (1, 324)
        end = (580, 1)

    elif difficulty == "my_maze.gif" or difficulty == "maps/my_maze.gif":
        start = (0, 0)
        end = (500, 205)

    elif difficulty == "my_maze2.gif" or difficulty == "maps/my_maze2.gif":
        start = (0, 0)
        end = (599, 350)

    else:
        assert False, "Incorrect difficulty level provided"
    
    # Initialize Dijkstra structures
    G = 10**18
    E = 10**18

    open_set.put((0, start))      # (priority, node)
    came_from[start] = None
    cost_so_far[start] = 0
    frontier[start] = True

    # Load maze
    im = Image.open(difficulty).convert('1')
    pixel_map = im.load()
    width, height = im.size

    # Run search
    search(pixel_map, width, height)

    # Terminal report
    print("Dijkstra completed")
    print("Start node: ", start)
    print("Goal node:  ", end)
    print("Final path cost: ", G)
    print("Number of expanded nodes: ", len(expanded))
    print("Path length (pixels/nodes in path): ", len(path))
    print("Saved image: dijkstra_result.png")
    print("Saved labeled image: dijkstra_labeled_result.png")

    # Visualization
    visualize_search("dijkstra_result.png")